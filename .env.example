# Daily budget mode: conservative | default | expanded
TA_BUDGET_MODE=default

# News sources (comma-separated): Bloomberg,MarketWatch,FinancialTimes,WSJ,Benzinga
TA_NEWS_SOURCES=Bloomberg,MarketWatch,FinancialTimes

# Max candidates per pass
TA_CANDIDATES_LIGHTWEIGHT=5
TA_CANDIDATES_BANDAR=3
TA_CANDIDATES_DEEP=2

# SQLite database path
TA_DB_PATH=data/transaction_analysis.sqlite3

# Reports output directory
TA_REPORTS_DIR=reports

# RapidAPI credentials
RAPIDAPI_KEY=your_rapidapi_key_here

# Existing Hermes bot can call this engine through CLI commands or local API wrappers.
